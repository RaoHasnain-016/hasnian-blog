<%
function fmtDate(d){return new Date(d).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
function catColor(c){const m={'LLMs':'#1d4ed8','Computer Vision':'#6d28d9','AI Agents':'#047857','Reinforcement Learning':'#b45309','NLP':'#b91c1c','Generative AI':'#7c3aed','MLOps':'#0369a1','Node.js':'#15803d','Python':'#1d4ed8','Other':'#475569'};return m[c]||'#475569'}
function catBg(c){const m={'LLMs':'#dbeafe','Computer Vision':'#ede9fe','AI Agents':'#d1fae5','Reinforcement Learning':'#fef3c7','NLP':'#fee2e2','Generative AI':'#f3e8ff','MLOps':'#e0f2fe','Node.js':'#dcfce7','Python':'#dbeafe','Other':'#f1f5f9'};return m[c]||'#f1f5f9'}
function catEmoji(c){const m={'LLMs':'🧠','Computer Vision':'👁️','AI Agents':'🤖','Reinforcement Learning':'🎮','NLP':'💬','Generative AI':'🎨','MLOps':'🚀','Node.js':'🟢','Python':'🐍','Other':'📄'};return m[c]||'📄'}
%>
<%- include('../partials/header') %>

<section class="hero">
 <div class="hero-inner">
  <div class="hero-left">
   <div class="hero-badge"><span class="hb-dot"></span>AI &amp; Full Stack Developer</div>
   <h1 class="hero-title">
     Hi, I am<br>
     <span class="ht-name">Hasnain</span><br>
     <span class="ht-sub">I write about AI &amp; Tech</span>
   </h1>
   <p class="hero-desc">BSSE Student at COMSATS University Islamabad. I publish in-depth articles on <strong>Large Language Models</strong>, <strong>Neural Networks</strong>, <strong>Computer Vision</strong>, and modern full-stack web development.</p>
   <div class="hero-skills">
     <span>Python</span><span>Node.js</span><span>TensorFlow</span><span>MongoDB</span><span>LLMs</span><span>CV</span>
   </div>
   <div class="hero-cta">
     <a href="/blog" class="btn btn-primary"><i class="fas fa-book-open"></i> Read Articles</a>
     <a href="/register" class="btn btn-outline"><i class="fas fa-pen-nib"></i> Start Writing</a>
   </div>
   <div class="hero-stats">
     <div class="hst"><span class="hst-n"><%= total %>+</span><span class="hst-l">Articles</span></div>
     <div class="hst-sep"></div>
     <div class="hst"><span class="hst-n">10</span><span class="hst-l">Topics</span></div>
     <div class="hst-sep"></div>
     <div class="hst"><span class="hst-n">BSSE</span><span class="hst-l">COMSATS</span></div>
   </div>
  </div>

  <div class="hero-right">
   <div class="hero-card">
     <div class="hc-img-wrap">
       <img src="data:image/jpeg;base64," alt="Hasnain" class="hc-photo"/>
       <div class="hc-overlay"></div>
     </div>
     <div class="hc-info">
       <div class="hci-name">Hasnain</div>
       <div class="hci-role">AI Engineer &amp; Full Stack Developer</div>
       <div class="hci-tags"><span>Python</span><span>Node.js</span><span>MongoDB</span></div>
     </div>
   </div>
   <div class="hc-float-1"><span>🤖</span><div><div class="hf-val"><%= total %>+ Posts</div><div class="hf-lbl">Published</div></div></div>
   <div class="hc-float-2"><span style="color:#f59e0b">⚡</span><div><div class="hf-val">Live on Vercel</div><div class="hf-lbl">Deployed</div></div></div>
  </div>
 </div>
</section>

<section class="section" id="posts">
 <div class="section-inner">
  <div class="section-head">
   <div><p class="section-label">Featured Articles</p><h2 class="section-title">Latest from the Blog</h2></div>
   <a href="/blog" class="btn btn-outline btn-sm">View All <i class="fas fa-arrow-right"></i></a>
  </div>

  <% if(featured.length===0 && recent.length===0){ %>
   <div class="empty-box">
     <div class="eb-icon">✍️</div>
     <h3>No posts yet — be the first!</h3>
     <p>Register and write the first article on this blog.</p>
     <a href="/register" class="btn btn-primary" style="margin-top:1rem">Get Started</a>
   </div>
  <% } else { %>
   <% if(featured.length>0){ %>
   <div class="feat-grid">
    <a href="/blog/<%= featured[0]._id %>" class="feat-big">
     <div class="fp-top" style="background:<%=catBg(featured[0].category)%>">
       <span class="fp-emo"><%=catEmoji(featured[0].category)%></span>
       <% if(featured[0].image){ %><img src="/uploads/<%=featured[0].image%>" class="fp-img" alt=""/><% } %>
     </div>
     <div class="fp-body">
       <span class="cat-tag" style="background:<%=catBg(featured[0].category)%>;color:<%=catColor(featured[0].category)%>"><%=featured[0].category%></span>
       <h2 class="fp-title"><%=featured[0].title%></h2>
       <p class="fp-exc"><%=(featured[0].excerpt||'').substring(0,150)%>…</p>
       <div class="fp-meta">
         <div class="fp-author"><div class="fp-av"><%=featured[0].author.username.charAt(0).toUpperCase()%></div><span><%=featured[0].author.username%></span></div>
         <span class="fp-date"><%=fmtDate(featured[0].createdAt)%></span>
       </div>
     </div>
    </a>
    <div class="feat-col">
     <% for(let i=1;i<Math.min(featured.length,3);i++){ %>
     <a href="/blog/<%=featured[i]._id%>" class="feat-sm">
      <div class="fps-img" style="background:<%=catBg(featured[i].category)%>">
        <span><%=catEmoji(featured[i].category)%></span>
        <% if(featured[i].image){ %><img src="/uploads/<%=featured[i].image%>" class="fp-img" alt=""/><% } %>
      </div>
      <div class="fps-body">
        <span class="cat-tag" style="background:<%=catBg(featured[i].category)%>;color:<%=catColor(featured[i].category)%>"><%=featured[i].category%></span>
        <h3 class="fps-title"><%=featured[i].title%></h3>
        <div class="fp-meta">
          <div class="fp-author"><div class="fp-av"><%=featured[i].author.username.charAt(0).toUpperCase()%></div><span><%=featured[i].author.username%></span></div>
          <span class="fp-date"><%=fmtDate(featured[i].createdAt)%></span>
        </div>
      </div>
     </a>
     <% } %>
    </div>
   </div>
   <% } %>

   <% if(recent.length>0){ %>
   <div class="section-head" style="margin-top:3rem">
     <div><p class="section-label">Recent Articles</p><h2 class="section-title" style="font-size:1.6rem">More to Explore</h2></div>
   </div>
   <div class="posts-grid">
    <% recent.forEach(p=>{ %>
    <a href="/blog/<%=p._id%>" class="post-card">
     <div class="pc-top" style="background:<%=catBg(p.category)%>">
       <span><%=catEmoji(p.category)%></span>
       <% if(p.image){ %><img src="/uploads/<%=p.image%>" class="fp-img" alt=""/><% } %>
     </div>
     <div class="pc-body">
       <span class="cat-tag" style="background:<%=catBg(p.category)%>;color:<%=catColor(p.category)%>"><%=p.category%></span>
       <h3 class="pc-title"><%=p.title%></h3>
       <p class="pc-exc"><%=(p.excerpt||'').substring(0,90)%>…</p>
       <div class="fp-meta">
         <div class="fp-author"><div class="fp-av"><%=p.author.username.charAt(0).toUpperCase()%></div><span><%=p.author.username%></span></div>
         <span class="pc-views"><i class="fas fa-eye"></i> <%=p.views%></span>
       </div>
     </div>
    </a>
    <% }) %>
   </div>
   <% } %>

   <div style="text-align:center;margin-top:2.5rem">
     <a href="/blog" class="btn btn-primary"><i class="fas fa-newspaper"></i> Browse All Articles</a>
   </div>
  <% } %>
 </div>
</section>

<section class="deploy-section">
 <div class="section-inner">
  <div class="deploy-card">
   <div class="deploy-left">
    <p class="section-label" style="color:#93c5fd">Deployment</p>
    <h2 class="deploy-title">Live on Vercel</h2>
    <p class="deploy-desc">This blog is deployed on <strong>Vercel</strong> with MongoDB Atlas as the cloud database — zero server management, instant global delivery.</p>
    <div class="deploy-steps">
      <div class="ds"><span class="ds-n">1</span><span>Create MongoDB Atlas free cluster</span></div>
      <div class="ds"><span class="ds-n">2</span><span>Push code to GitHub</span></div>
      <div class="ds"><span class="ds-n">3</span><span>Import repo on Vercel</span></div>
      <div class="ds"><span class="ds-n">4</span><span>Set environment variables</span></div>
      <div class="ds"><span class="ds-n">5</span><span>Click Deploy — go live 🚀</span></div>
    </div>
   </div>
   <div class="deploy-right">
    <div class="dc-block">
     <div class="dc-bar"><span></span><span></span><span></span><span class="dc-name">vercel.json</span></div>
     <pre class="dc-pre">{
  <span class="dk">"version"</span>: <span class="dv">2</span>,
  <span class="dk">"builds"</span>: [{
    <span class="dk">"src"</span>: <span class="dstr">"app.js"</span>,
    <span class="dk">"use"</span>: <span class="dstr">"@vercel/node"</span>
  }],
  <span class="dk">"routes"</span>: [{
    <span class="dk">"src"</span>: <span class="dstr">"/(.*)"</span>,
    <span class="dk">"dest"</span>: <span class="dstr">"app.js"</span>
  }]
}</pre>
    </div>
    <div class="dc-env">
      <div class="de-row"><span class="de-k">MONGODB_URI</span><span class="de-v">mongodb+srv://...</span></div>
      <div class="de-row"><span class="de-k">SESSION_SECRET</span><span class="de-v">your_secret</span></div>
      <div class="de-row"><span class="de-k">NODE_ENV</span><span class="de-v">production</span></div>
    </div>
   </div>
  </div>
 </div>
</section>

<%- include('../partials/footer') %>
