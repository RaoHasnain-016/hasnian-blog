<%- include('../partials/header') %>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">✦ Hasnain<span>.</span>Blog</div>
    <h2 class="auth-title">Welcome Back</h2>
    <p class="auth-sub">Sign in to your account</p>

    <% if(errors.length>0){ %>
      <div class="alert alert-error">
        <i class="fas fa-exclamation-circle"></i>
        <ul><% errors.forEach(e=>{%><li><%=e.msg%></li><%})%></ul>
      </div>
    <% } %>

    <form action="/login" method="POST">
      <div class="fg">
        <label class="flabel">Email <span class="req">*</span></label>
        <div class="finput-wrap"><i class="fas fa-envelope fi-icon"></i>
          <input class="finput" type="email" name="email" value="<%=old.email||''%>" placeholder="you@example.com" required/>
        </div>
      </div>
      <div class="fg">
        <label class="flabel">Password <span class="req">*</span></label>
        <div class="finput-wrap"><i class="fas fa-lock fi-icon"></i>
          <input class="finput" type="password" name="password" placeholder="Your password" required/>
        </div>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:.8rem">
        <i class="fas fa-sign-in-alt"></i> Login
      </button>
    </form>
    <p class="auth-foot">No account? <a href="/register">Register here</a></p>
  </div>
</div>
<%- include('../partials/footer') %>
