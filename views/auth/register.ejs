<%- include('../partials/header') %>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">✦ Hasnain<span>.</span>Blog</div>
    <h2 class="auth-title">Create Account</h2>
    <p class="auth-sub">Join the community and start writing</p>

    <% if(errors.length>0){ %>
      <div class="alert alert-error">
        <i class="fas fa-exclamation-circle"></i>
        <ul><% errors.forEach(e=>{%><li><%=e.msg%></li><%})%></ul>
      </div>
    <% } %>

    <form action="/register" method="POST">
      <div class="fg">
        <label class="flabel">Username <span class="req">*</span></label>
        <div class="finput-wrap"><i class="fas fa-user fi-icon"></i>
          <input class="finput" type="text" name="username" value="<%=old.username||''%>" placeholder="Min 3 characters" required/>
        </div>
      </div>
      <div class="fg">
        <label class="flabel">Email <span class="req">*</span></label>
        <div class="finput-wrap"><i class="fas fa-envelope fi-icon"></i>
          <input class="finput" type="email" name="email" value="<%=old.email||''%>" placeholder="you@example.com" required/>
        </div>
      </div>
      <div class="fg">
        <label class="flabel">Password <span class="req">*</span></label>
        <div class="finput-wrap"><i class="fas fa-lock fi-icon"></i>
          <input class="finput" type="password" name="password" placeholder="Min 6 characters" required/>
        </div>
      </div>
      <div class="fg">
        <label class="flabel">Confirm Password <span class="req">*</span></label>
        <div class="finput-wrap"><i class="fas fa-lock fi-icon"></i>
          <input class="finput" type="password" name="confirmPassword" placeholder="Repeat password" required/>
        </div>
      </div>
      <div class="fg">
        <label class="flabel">Bio <span class="opt">(optional)</span></label>
        <textarea class="finput" name="bio" rows="2" maxlength="200" placeholder="Tell us about yourself…" style="padding:.62rem .9rem"><%=old.bio||''%></textarea>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:.8rem">
        <i class="fas fa-user-plus"></i> Create Account
      </button>
    </form>
    <p class="auth-foot">Already have an account? <a href="/login">Login here</a></p>
  </div>
</div>
<%- include('../partials/footer') %>
